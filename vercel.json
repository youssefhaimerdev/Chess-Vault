{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/trainer", "destination": "/trainer.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/scotch-game-guide", "destination": "/blog/scotch-game-guide.html" },
    { "source": "/blog/how-to-study-openings", "destination": "/blog/how-to-study-openings.html" },
    { "source": "/blog/caro-kann-guide", "destination": "/blog/caro-kann-guide.html" },
    { "source": "/blog/opera-game-analysis", "destination": "/blog/opera-game-analysis.html" },
    { "source": "/blog/immortal-game-analysis", "destination": "/blog/immortal-game-analysis.html" },
    { "source": "/blog/french-advance-guide", "destination": "/blog/french-advance-guide.html" },
    { "source": "/blog/nimzo-indian-guide", "destination": "/blog/nimzo-indian-guide.html" },
    { "source": "/blog/sicilian-alapin", "destination": "/blog/sicilian-alapin.html" },
    { "source": "/blog/opening-mistakes", "destination": "/blog/opening-mistakes.html" },
    { "source": "/blog/how-to-study-famous-games", "destination": "/blog/how-to-study-famous-games.html" }
  ]
}
